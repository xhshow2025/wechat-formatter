# Neon 数据库连接字符串 (在 Neon 后台创建项目后获取)
DATABASE_URL="postgresql://..."

# NextAuth 密钥 (运行 openssl rand -base64 32 生成)
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# 邮箱验证服务（使用 Resend HTTP API）
RESEND_API_KEY="re_xxx"
EMAIL_FROM="微信公众号排版工具 <noreply@example.com>"

# 腾讯云 COS 图床配置
TENCENT_SECRET_ID="你的 SecretId"
TENCENT_SECRET_KEY="你的 SecretKey"
TENCENT_BUCKET="你的存储桶名称，例如 mybucket-1250000000"
TENCENT_REGION="你的存储桶地域，例如 ap-guangzhou"
